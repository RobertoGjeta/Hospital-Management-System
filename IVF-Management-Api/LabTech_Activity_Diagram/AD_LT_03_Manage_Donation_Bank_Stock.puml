@startuml AD_LT_03_Manage_Donation_Bank_Stock

title AD_LT_03 — Manage Donation Bank Stock & Donor Sample Status

|Lab Technician|
|System|

|Lab Technician|

note
  Prerequisites:
  - AD_LT_00 User Authenticated
  - Donation Bank module configured
  - At least one donor record exists
end note

start

:Open Donation Bank module;

|System|

:Display current inventory:\ntype, donor ID, quantity,\ncollection date, expiry,\nstorage location, screening status;

|Lab Technician|

:Select action;

if (Action?) then (Add New Sample)
  :Enter donor ID, sample type,\nquantity, collection date,\nstorage location;

  |System|

  if (Donor ID found?) then (no)
    :Prompt to register donor first;
    |Lab Technician|
    :Register donor;
    |System|
  else (yes)
  endif

  :Add sample with status = Pending;
  :Log chain-of-custody\n'Received' event;

else (Update Screening Status)
  |Lab Technician|
  :Select donor sample;
  :Set status: Cleared or Rejected;
  :Enter mandatory reason note;

  |System|

  if (Reason note provided?) then (no)
    :Block submission;\nReason note required;
    |Lab Technician|
    :Enter reason note;
    |System|
  else (yes)
  endif

  :Update sample screening status;

  if (Status = Rejected?) then (yes)
    :Remove sample from\nassignable pool immediately;
  else (no)
  endif

else (Mark as Expired)
  |Lab Technician|
  :Select expired sample;

  |System|

  :Lock sample from\npatient assignment;
  :Flag as expired\nin inventory;

else (Update Quantity)
  |Lab Technician|
  :Update stock quantity\nfor sample type;
  |System|
  :Save updated quantity;
endif

|System|

if (Stock below minimum threshold?) then (yes)
  :Send low-stock alert to\nLab Technician + Hospital Admin;
else (no)
endif

:Display updated inventory;

|Lab Technician|

:View updated inventory;

stop

@enduml
