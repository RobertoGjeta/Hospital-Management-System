@startuml SeqD_LT_04_Log_Sample_Chain_of_Custody

title SeqD_LT_04 — Log Sample Chain-of-Custody Event

actor "Lab Technician" as LT
participant "Sample Tracking UI" as UI
participant "LabTechnicianController" as CTRL
participant "LabTechnicianService" as SVC
participant "AppDbContext" as DB

== View Custody History ==

LT -> UI : Navigate to Sample Tracking\nScan barcode or enter sample ID
UI -> CTRL : GET /api/labtechnician/custody/{sampleId}
CTRL -> SVC : GetSampleCustodyHistoryAsync(sampleId)
SVC -> DB : SELECT events WHERE sample_id = sampleId\nORDER BY event_timestamp ASC
DB --> SVC : custody event list
SVC --> CTRL : history
CTRL --> UI : 200 OK — custody history

alt Sample ID not found
  DB --> SVC : empty
  SVC --> CTRL : 404 Not Found
  CTRL --> UI : 404 Not Found
  UI --> LT : Show error — verify or register sample first
end

UI --> LT : Display full custody log

== Log New Custody Event ==

LT -> UI : Select event type\n(Received / Processed / Stored / Transferred / Discarded)

alt Event = Transferred
  LT -> UI : Enter recipient name + role / department
end

alt Event = Discarded
  LT -> UI : Select disposal reason code\nEnter disposal method
  LT -> UI : Confirm disposal
end

UI -> CTRL : POST /api/labtechnician/custody\n{sampleId, eventType, recipient?, reasonCode?, notes}
CTRL -> SVC : LogCustodyEventAsync(dto, techId)

alt Discarded — reason code missing
  SVC --> CTRL : ArgumentException
  CTRL --> UI : 400 Bad Request
  UI --> LT : Reason code required
end

alt Transferred — recipient missing
  SVC --> CTRL : ArgumentException
  CTRL --> UI : 400 Bad Request
  UI --> LT : Recipient name required
end

SVC -> DB : INSERT SampleCustodyEvent\n(type, timestamp, techId, notes)
DB --> SVC : event saved (immutable)
SVC --> CTRL : SampleCustodyEvent
CTRL --> UI : 201 Created
UI --> LT : Updated custody log displayed

@enduml
