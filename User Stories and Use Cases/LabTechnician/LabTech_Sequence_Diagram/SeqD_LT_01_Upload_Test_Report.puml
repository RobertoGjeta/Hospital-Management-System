@startuml SeqD_LT_01_Upload_Test_Report

title SeqD_LT_01 — Upload Test Report

actor "Lab Technician" as LT
participant "Test Queue UI" as UI
participant "LabTechnicianController" as CTRL
participant "LabTechnicianService" as SVC
participant "AppDbContext" as DB
participant "NotificationService" as NOTIF

== Main Sequence ==

LT -> UI : Open test queue
UI -> CTRL : GET /api/labtechnician/test-queue
CTRL -> SVC : GetPendingTestQueueAsync()
SVC -> DB : SELECT orders WHERE status='Pending'\nORDER BY urgency, due_time
DB --> SVC : order list
SVC --> CTRL : sorted queue
CTRL --> UI : 200 OK — queue list
UI --> LT : Display prioritised test queue

LT -> UI : Select order + upload result file
UI -> CTRL : POST /api/labtechnician/test-reports\n(multipart/form-data: dto + file)

CTRL -> CTRL : Validate file format & size ≤ 25 MB

alt File invalid (wrong format or > 25 MB)
  CTRL --> UI : 400 Bad Request
  UI --> LT : Show inline error
end

CTRL -> SVC : UploadTestReportAsync(dto, filePath, techId)
SVC -> SVC : CheckAbnormal(resultValues, testType)

alt Abnormal result detected
  SVC -> NOTIF : NotifyDoctorUrgentAsync(orderId, reportId)
  NOTIF --> SVC : urgent alert sent
end

SVC -> DB : INSERT TestReport (linked to order + patient)
DB --> SVC : report saved
SVC -> NOTIF : NotifyDoctorAsync(orderId)
NOTIF --> SVC : notification sent
SVC --> CTRL : TestReportResponseDto
CTRL --> UI : 201 Created — report response
UI --> LT : Show upload confirmation + audit entry

== Alternative: Doctor order not found ==

alt Order ID does not exist
  CTRL --> UI : 404 Not Found
  UI --> LT : Prompt to search by patient ID or doctor name
end

== Alternative: Unauthenticated technician ==

alt No valid JWT / wrong role
  CTRL --> UI : 401 Unauthorized
  UI --> LT : Redirect to login
end

@enduml
