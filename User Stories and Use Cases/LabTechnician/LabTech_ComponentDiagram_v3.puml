@startuml LabTech_ComponentDiagram
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam linetype ortho

skinparam node {
  BackgroundColor #F5FDF9
  BorderColor #444441
  FontColor #1a1a1a
  FontSize 11
}

skinparam component {
  BackgroundColor #E1F5EE
  BorderColor #0F6E56
  FontColor #085041
  FontSize 11
  Style rectangle
}

skinparam arrow {
  Color #444441
  FontColor #444441
  FontSize 10
}

title Lab Technician — Component Diagram\nIVF Clinic Management System (.NET 8)\nSilvja Fejzulla — UC_LT_01 to UC_LT_05

node "Server Side (ASP.NET Core 8)" as Server {

  node "Controllers" as ColControllers {
    component "LabTestOrderController\nGET · POST /api/labtestorders" as C1
    component "LabTestReportController\nGET · PUT /api/labreports" as C2
    component "EmbryoObservationController\nPOST · GET /api/observations" as C3
  }

  node "Services" as ColServices {
    component "ILabTestOrderService" as IS1
    component "ILabTestReportService" as IS2
    component "IEmbryoObservationService" as IS3
    component "LabTestOrderService" as S1
    component "LabTestReportService" as S2
    component "EmbryoObservationService" as S3
  }

  node "Models" as ColModels {
    component "LabTestOrder" as M1
    component "LabTestReport\n(IsAbnormal · IsCritical)" as M2
    component "EmbryoObservation" as M3
    component "ChainOfCustodyLog" as M4
    component "Embryo" as M5
    component "LabTechnician" as M6
  }

  component "IVFClinicDbContext\n(EF Core + Migrations)" as DbCtx
}

node "Client Side\n<<device>>" as ClientSide {
  component "Frontend Web App\n(React / HTML)" as FrontEnd
}

node "Database Server\n<<device>>\nAzure SQL" as SqlServer {
  component "Microsoft SQL Server\nIVFClinicDatabase" as DB
}

' ─── Communication Paths ───
FrontEnd --> Server    : "HTTP Request/Response (JSON)"
Server   --> SqlServer : "DbContext (Migrations)\nADO.NET · TCP 1433"

' ─── Controller -> Interface ───
C1 ..> IS1 : uses
C2 ..> IS2 : uses
C3 ..> IS3 : uses

' ─── Interface -> Implementation ───
IS1 ..> S1 : implements
IS2 ..> S2 : implements
IS3 ..> S3 : implements

' ─── Service -> Model ───
S1 ..> M1 : uses
S2 ..> M2 : uses
S3 ..> M3 : uses
S1 ..> M4 : uses
S3 ..> M5 : uses

' ─── Models -> DbContext ───
ColModels ..> DbCtx : uses

@enduml
