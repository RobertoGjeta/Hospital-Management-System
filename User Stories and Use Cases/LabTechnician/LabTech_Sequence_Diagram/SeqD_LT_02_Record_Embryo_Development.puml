@startuml SeqD_LT_02_Record_Embryo_Development

title SeqD_LT_02 — Record Embryo Development & Cryopreservation

actor "Lab Technician" as LT
participant "Embryology UI" as UI
participant "LabTechnicianController" as CTRL
participant "LabTechnicianService" as SVC
participant "AppDbContext" as DB

== Main Sequence ==

LT -> UI : Open Embryology Module
UI -> CTRL : GET /api/labtechnician/cycle/{cycleId}/embryos
CTRL -> SVC : GetEmbryosByCycleAsync(cycleId, techId)
SVC -> DB : SELECT embryos + doctor instructions\nWHERE cycle_id = cycleId
DB --> SVC : embryo list + instructions
SVC --> CTRL : embryo data
CTRL --> UI : 200 OK — embryo list
UI --> LT : Display embryos + doctor freeze/transfer instructions

LT -> UI : Select embryo, enter observation data\n(day, cell count, frag%, grade, notes)
UI -> CTRL : POST /api/labtechnician/embryo-development\n(multipart/form-data: dto + optional image)

CTRL -> CTRL : Validate mandatory fields\n(day, cell count, grade)

alt Mandatory field missing
  CTRL --> UI : 400 Bad Request — missing fields
  UI --> LT : Highlight missing fields
end

alt Microscopy image attached
  CTRL -> CTRL : Check image size ≤ 10 MB
  alt Image > 10 MB
    CTRL --> UI : 400 Bad Request — image too large
    UI --> LT : Show size error
  end
end

CTRL -> SVC : RecordEmbryoDevelopmentAsync(dto, imagePath, techId)
SVC -> DB : INSERT EmbryoDevelopment (immutable entry)
DB --> SVC : entry saved
SVC --> CTRL : EmbryoDevelopment record
CTRL --> UI : 201 Created
UI --> LT : Confirm observation saved

== Cryopreservation Sub-sequence ==

LT -> UI : Select "Freeze Embryo"\nEnter tank, cane, straw, date, method
UI -> CTRL : POST /api/labtechnician/embryo-development/freeze\n{embryoId, storageTank, cane, straw, date, method}
CTRL -> SVC : FreezeEmbryoAsync(dto, techId)
SVC -> DB : INSERT Cryopreservation record
SVC -> DB : UPDATE Embryo SET status = 'Frozen'
DB --> SVC : saved
SVC --> CTRL : Cryopreservation record
CTRL --> UI : 201 Created
UI --> LT : Embryo status updated to Frozen

== Alternative: Cycle cancelled by doctor ==

alt IVF cycle is cancelled
  SVC --> CTRL : 409 Conflict — cycle cancelled
  CTRL --> UI : 409 Conflict
  UI --> LT : Show cancellation notice;\nAllow final note only
end

@enduml
